-- Safe Zone System for Roblox Studio
-- Place this script in ServerScriptService

local SafeZoneSystem = {}

-- Configuration
local SAFE_ZONE_CENTER = Vector3.new(0, 5, 0)        -- Center position of safe zone
local SAFE_ZONE_RADIUS = 50                          -- Radius of safe zone
local SAFE_ZONE_HEIGHT = 30                          -- Height of safe zone

-- Create safe zone part (visual indicator)
local function createSafeZoneVisual()
    local safeZone = Instance.new("Part")
    safeZone.Name = "SafeZone"
    safeZone.Shape = Enum.PartType.Cylinder
    safeZone.Size = Vector3.new(SAFE_ZONE_HEIGHT, SAFE_ZONE_RADIUS * 2, SAFE_ZONE_RADIUS * 2)
    safeZone.Color = Color3.fromRGB(0, 200, 0)
    safeZone.Material = Enum.Material.Neon
    safeZone.CanCollide = false
    safeZone.Anchored = true
    safeZone.Position = SAFE_ZONE_CENTER
    safeZone.Transparency = 0.7
    safeZone.TopSurface = Enum.SurfaceType.Smooth
    safeZone.BottomSurface = Enum.SurfaceType.Smooth
    safeZone.Parent = workspace
    
    return safeZone
end

-- Function to check if position is in safe zone
function SafeZoneSystem:isInSafeZone(position)
    local distance = (position - SAFE_ZONE_CENTER).Magnitude
    return distance <= SAFE_ZONE_RADIUS
end

-- Function to set player spawn location in safe zone
local function setSpawnLocation()
    local Players = game:GetService("Players")
    
    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(character)
            local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
            -- Spawn player in safe zone
            humanoidRootPart.CFrame = CFrame.new(SAFE_ZONE_CENTER + Vector3.new(0, 15, 0))
        end)
    end)
end

-- Hook into meteor system to prevent meteors in safe zone
function SafeZoneSystem:shouldBlockMeteor(position)
    return self:isInSafeZone(position)
end

-- Create visual safe zone
createSafeZoneVisual()

-- Set spawn location
setSpawnLocation()

print("Safe Zone System initialized at: " .. tostring(SAFE_ZONE_CENTER))

return SafeZoneSystem
