-- Player Movement System for Roblox Studio
-- Place this script in StarterPlayer > StarterPlayerScripts

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- Configuration
local SPRINT_SPEED = 50          -- Sprint speed
local WALK_SPEED = 16            -- Normal walk speed
local DASH_SPEED = 100           -- Dash speed
local DASH_DURATION = 0.5        -- How long dash lasts (seconds)
local DASH_COOLDOWN = 1.5        -- Cooldown between dashes (seconds)
local SPRINT_STAMINA_DRAIN = 0.5 -- Stamina drain per second while sprinting
local DASH_STAMINA_COST = 30     -- Stamina cost per dash
local MAX_STAMINA = 100          -- Maximum stamina
local STAMINA_REGEN = 1          -- Stamina regen per second

-- Player state variables
local stamina = MAX_STAMINA
local isSprinting = false
local canDash = true
local dashDirection = Vector3.new(0, 0, 0)

-- Create stamina GUI
local function createStaminaGUI()
    local screenGui = Instance.new("ScreenGui")
    screenGui.ResetOnSpawn = false
    screenGui.Name = "StaminaGui"
    screenGui.Parent = player:WaitForChild("PlayerGui")
    
    local staminaBar = Instance.new("TextLabel")
    staminaBar.Name = "StaminaBar"
    staminaBar.Size = UDim2.new(0, 200, 0, 30)
    staminaBar.Position = UDim2.new(0.5, -100, 1, -50)
    staminaBar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    staminaBar.BorderSizePixel = 2
    staminaBar.BorderColor3 = Color3.fromRGB(100, 100, 100)
    staminaBar.TextScaled = true
    staminaBar.TextColor3 = Color3.fromRGB(255, 255, 255)
    staminaBar.Parent = screenGui
    
    local staminaFill = Instance.new("Frame")
    staminaFill.Name = "StaminaFill"
    staminaFill.Size = UDim2.new(1, 0, 1, 0)
    staminaFill.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    staminaFill.BorderSizePixel = 0
    staminaFill.Parent = staminaBar
    
    return staminaBar, staminaFill
end

local staminaBar, staminaFill = createStaminaGUI()

-- Update stamina display
local function updateStaminaDisplay()
    local fillPercentage = stamina / MAX_STAMINA
    staminaFill.Size = UDim2.new(fillPercentage, 0, 1, 0)
    
    -- Change color based on stamina level
    if fillPercentage > 0.5 then
        staminaFill.BackgroundColor3 = Color3.fromRGB(0, 200, 0)  -- Green
    elseif fillPercentage > 0.25 then
        staminaFill.BackgroundColor3 = Color3.fromRGB(255, 200, 0)  -- Yellow
    else
        staminaFill.BackgroundColor3 = Color3.fromRGB(255, 0, 0)  -- Red
    end
    
    staminaBar.Text = "Stamina: " .. math.floor(stamina) .. "/" .. MAX_STAMINA
end

-- Sprint function
local function startSprint()
    if isSprinting then return end
    isSprinting = true
    humanoid.WalkSpeed = SPRINT_SPEED
end

local function stopSprint()
    isSprinting = false
    humanoid.WalkSpeed = WALK_SPEED
end

-- Dash function
local function dash()
    if not canDash or stamina < DASH_STAMINA_COST then
        return
    end
    
    canDash = false
    stamina = stamina - DASH_STAMINA_COST
    
    -- Get the direction the player is moving
    local camera = workspace.CurrentCamera
    local moveDirection = Vector3.new(0, 0, 0)
    
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + (camera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - (camera.CFrame.LookVector * Vector3.new(1, 0, 1)).Unit
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - camera.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + camera.CFrame.RightVector
    end
    
    -- If no direction input, dash forward
    if moveDirection.Magnitude == 0 then
        moveDirection = camera.CFrame.LookVector
    else
        moveDirection = moveDirection.Unit
    end
    
    -- Create dash velocity
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = moveDirection * DASH_SPEED
    bodyVelocity.MaxForce = Vector3.new(math.huge, 0, math.huge)
    bodyVelocity.Parent = humanoidRootPart
    
    task.wait(DASH_DURATION)
    bodyVelocity:Destroy()
    
    -- Dash cooldown
    task.wait(DASH_COOLDOWN)
    canDash = true
end

-- Input handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Lshift then
        startSprint()
    end
    
    if input.KeyCode == Enum.KeyCode.Space then
        dash()
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Lshift then
        stopSprint()
    end
end)

-- Stamina system
game:GetService("RunService").Heartbeat:Connect(function()
    -- Drain stamina while sprinting
    if isSprinting then
        stamina = stamina - SPRINT_STAMINA_DRAIN * game:GetService("RunService").Heartbeat:Wait()
        if stamina <= 0 then
            stamina = 0
            stopSprint()
        end
    else
        -- Regenerate stamina when not sprinting
        stamina = math.min(stamina + STAMINA_REGEN * game:GetService("RunService").Heartbeat:Wait(), MAX_STAMINA)
    end
    
    updateStaminaDisplay()
end)

-- Handle character respawn
player.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
    stamina = MAX_STAMINA
    isSprinting = false
    canDash = true
end)
